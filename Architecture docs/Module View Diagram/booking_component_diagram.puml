@startuml
' =========================
' Booking Subsystem - UML Component Diagram 
' Backend + Database + Frontend
' =========================

' Backend Modules 
package "BookingModule" <<module>> {
    [BookingController] <<component>>
    [BookingService] <<component>>
    [Booking] <<entity>>
}

package "UserModule" <<module>> {
    [User] <<entity>>
}

package "RoomModule" <<module>> {
    [Room] <<entity>>
}

package "TimeslotModule" <<module>> {
    [Timeslot] <<entity>>
}

[Database] <<component>>

' Frontend
package "Frontend (React)" <<module>> {
    [BookingUI] <<component>>
}

'  Relationships
[BookingUI] --> [BookingController] : calls
[BookingController] --> [BookingService] : invokes
[BookingService] --> [Booking] : manages
[BookingService] --> [Database] : persists
[BookingService] --> [User] : references
[BookingService] --> [Room] : references
[BookingService] --> [Timeslot] : references

[User] --> [Database]
[Room] --> [Database]
[Timeslot] --> [Database]
@enduml